# SMTP — Kontaktformular (Impressum)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Empfänger & Absender (CONTACT_FROM = Absender für Bestätigungs-Mail an Nutzer)
CONTACT_TO=hallo@cavara.dev
CONTACT_FROM="diggy Kontaktformular" <noreply@example.com>

# Geheimer Schlüssel für Anti-Spam-Token (zufällige lange Zeichenkette — in Produktion Pflicht)
CONTACT_FORM_SECRET=

# Hinter Reverse-Proxy (nginx, Caddy): true setzen für korrektes IP-Rate-Limiting
# TRUST_PROXY=true

# Optional: PageSpeed, VirusTotal, Port
# PAGESPEED_API_KEY=
# VIRUS_TOTAL_API_KEY=
# PORT=3001
